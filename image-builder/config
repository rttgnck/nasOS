# nasOS pi-gen configuration
# This file is sourced by pi-gen's build-docker.sh

IMG_NAME="nasOS"
RELEASE="bookworm"
TARGET_HOSTNAME="nasos"
FIRST_USER_NAME="nasos"
FIRST_USER_PASS="nasos"        # Changed on first boot via wizard
ENABLE_SSH="1"
DISABLE_FIRST_BOOT_WIZARD="1"  # We have our own first-boot wizard
LOCALE_DEFAULT="en_US.UTF-8"
KEYBOARD_KEYMAP="us"
KEYBOARD_LAYOUT="English (US)"
TIMEZONE_DEFAULT="UTC"

# Build stages: base Raspberry Pi OS Lite + our custom stage
STAGE_LIST="stage0 stage1 stage2 stage-nasos"

# Output format
DEPLOY_COMPRESSION="zip"  # Wrap the image in a .zip archive (DEPLOY_ZIP is deprecated)
USE_QEMU="0"              # Use native QEMU acceleration where possible

# Image size
# Root needs room for: Pi OS Lite (~1.8 GB) + Node.js/Docker/cage packages (~0.8 GB) +
# /opt/nasos install (venv 200 MB + electron 200 MB + backend/frontend ~80 MB) +
# OTA working set (extract ~50 MB + rollback ~50 MB + pip temp ~100 MB) +
# journald cap (200 MB) + Docker daemon state (~200 MB on root even with data-root
# moved to the data partition).  6 GB gives ~2 GB of sustained headroom.
# User NAS data lives on partition 3 (all remaining SD-card space) via setup-data-partition.sh.
BOOT_SIZE="256"        # Boot partition in MB
ROOT_SIZE="6144"       # Root in MB (6 GB)
