# /etc/sudoers.d/nasos-backend
# Allow the nasOS backend service user to manage shares and services.
# Installed by nasOS first-boot setup.
#
# NOTE: The username below is patched by first-boot.sh if Pi Imager
# renamed the default user from 'nasos' to something else.

nasos ALL=(root) NOPASSWD: /opt/nasos/scripts/share-helper.sh *
nasos ALL=(root) NOPASSWD: /opt/nasos/scripts/share-helper.sh

# OTA updates — apply script must run in its own systemd scope so it survives
# the nasos-backend.service restart it triggers mid-update.
nasos ALL=(root) NOPASSWD: /usr/bin/systemd-run --unit=nasos-apply-update --description=nasOS OTA apply --collect /opt/nasos/scripts/apply-update.sh *
nasos ALL=(root) NOPASSWD: /opt/nasos/scripts/apply-update.sh *

# Power management — restart and shutdown from the web UI
nasos ALL=(root) NOPASSWD: /usr/bin/systemctl reboot
nasos ALL=(root) NOPASSWD: /usr/bin/systemctl poweroff
